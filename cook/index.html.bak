<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>COOK — Orchestrator Brain — KTANA</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Zen+Dots&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', -apple-system, system-ui, sans-serif; background: #0A0A0A; color: #F5F5F7; min-height: 100vh; -webkit-font-smoothing: antialiased; }

    /* Layout */
    .header { position: sticky; top: 0; z-index: 50; padding: 16px 32px; border-bottom: 0.5px solid rgba(255,255,255,0.04); background: rgba(10,10,10,0.85); backdrop-filter: blur(20px); display: flex; align-items: center; justify-content: space-between; }
    .header-left { display: flex; align-items: center; gap: 12px; }
    .logo { font-family: 'Zen Dots', cursive; font-size: 15px; color: #D70030; }
    .logo-sub { font-size: 10px; color: #48484A; letter-spacing: 0.1em; text-transform: uppercase; }
    .header-right { display: flex; align-items: center; gap: 12px; font-size: 10px; color: #48484A; }
    .pulse { width: 6px; height: 6px; border-radius: 50%; background: #30D158; animation: pulse 2s ease-in-out infinite; }
    @keyframes pulse { 0%,100% { box-shadow: 0 0 4px rgba(48,209,88,0.3); } 50% { box-shadow: 0 0 14px rgba(48,209,88,0.6); } }

    .content { display: grid; grid-template-columns: 340px 1fr; min-height: calc(100vh - 53px); }

    /* Left panel — Agents + Feed */
    .left-panel { border-right: 0.5px solid rgba(255,255,255,0.04); overflow-y: auto; max-height: calc(100vh - 53px); }
    .panel-section { padding: 20px 16px; border-bottom: 0.5px solid rgba(255,255,255,0.04); }
    .panel-label { font-size: 9px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #D70030; margin-bottom: 12px; display: flex; align-items: center; justify-content: space-between; }
    .panel-count { font-size: 9px; color: #48484A; font-weight: 400; }

    /* Agent cards mini */
    .agent-mini { display: flex; align-items: center; gap: 10px; padding: 8px 10px; border-radius: 10px; margin-bottom: 4px; transition: background 0.15s; cursor: pointer; }
    .agent-mini:hover { background: rgba(255,255,255,0.03); }
    .agent-mini.active { background: rgba(215,0,48,0.06); }
    .a-av { width: 28px; height: 28px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-family: 'Zen Dots', cursive; font-size: 10px; flex-shrink: 0; }
    .a-av-ceo { background: rgba(215,0,48,0.1); color: #D70030; border: 1px solid rgba(215,0,48,0.2); }
    .a-av-def { background: rgba(255,255,255,0.03); color: #8E8E93; border: 1px solid rgba(255,255,255,0.06); }
    .a-name { font-size: 12px; font-weight: 500; }
    .a-role { font-size: 9px; color: #636366; }
    .a-status { font-size: 8px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.03em; display: flex; align-items: center; gap: 3px; margin-left: auto; }
    .a-status.on { color: #30D158; }
    .a-status.off { color: #48484A; }
    .dot { width: 4px; height: 4px; border-radius: 50%; }
    .dot-on { background: #30D158; animation: pulse 2s ease infinite; }

    /* Feed */
    .feed { max-height: 400px; overflow-y: auto; }
    .f-item { padding: 12px 0; border-bottom: 0.5px solid rgba(255,255,255,0.02); }
    .f-item:last-child { border: none; }
    .f-row { display: flex; align-items: center; gap: 4px; margin-bottom: 4px; flex-wrap: wrap; }
    .f-from { font-size: 11px; font-weight: 600; color: #D2D2D7; }
    .f-arrow { font-size: 9px; color: #48484A; }
    .f-to { font-size: 11px; font-weight: 500; color: #8E8E93; }
    .f-time { font-size: 9px; color: #48484A; margin-left: auto; font-variant-numeric: tabular-nums; }
    .f-msg { font-size: 12px; color: #AEAEB2; line-height: 1.5; }
    .f-tags { display: flex; gap: 4px; margin-top: 6px; flex-wrap: wrap; }
    .f-tag { font-size: 8px; font-weight: 600; padding: 2px 6px; border-radius: 3px; text-transform: uppercase; letter-spacing: 0.03em; }
    .tag-delegate { background: rgba(0,122,255,0.12); color: #0A84FF; }
    .tag-respond { background: rgba(48,209,88,0.12); color: #30D158; }
    .tag-execute { background: rgba(191,90,242,0.12); color: #BF5AF2; }
    .tag-decide { background: rgba(255,159,10,0.12); color: #FF9F0A; }
    .tag-escalate { background: rgba(255,69,58,0.12); color: #FF453A; }
    .tag-meta { background: rgba(255,255,255,0.04); color: #636366; }
    .typing-line { display: flex; align-items: center; gap: 8px; padding: 10px 0; font-size: 11px; color: #636366; }
    .typing-dots { display: inline-flex; gap: 2px; }
    .typing-dots span { width: 3px; height: 3px; border-radius: 50%; background: #636366; animation: typ 1.2s ease infinite; }
    .typing-dots span:nth-child(2) { animation-delay: 0.15s; }
    .typing-dots span:nth-child(3) { animation-delay: 0.3s; }
    @keyframes typ { 0%,60%,100% { opacity: 0.2; } 30% { opacity: 1; } }

    /* Right panel — Frameworks */
    .right-panel { overflow-y: auto; max-height: calc(100vh - 53px); padding: 20px 24px; }
    .right-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
    .right-title { font-size: 10px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #D70030; }
    .filter-bar { display: flex; gap: 4px; }
    .filter-btn { font-size: 9px; padding: 4px 10px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.06); background: transparent; color: #636366; cursor: pointer; transition: all 0.15s; }
    .filter-btn:hover, .filter-btn.active { background: rgba(215,0,48,0.1); color: #D70030; border-color: rgba(215,0,48,0.2); }

    /* Stats mini */
    .stats-row { display: grid; grid-template-columns: repeat(5,1fr); gap: 8px; margin-bottom: 20px; }
    .stat-mini { background: #1C1C1E; border: 1px solid rgba(255,255,255,0.04); border-radius: 10px; padding: 12px; text-align: center; }
    .stat-mini-val { font-family: 'Zen Dots', cursive; font-size: 20px; }
    .stat-mini-label { font-size: 9px; color: #48484A; margin-top: 2px; text-transform: uppercase; letter-spacing: 0.04em; }

    /* Framework cards */
    .fw-list { display: flex; flex-direction: column; gap: 6px; }
    .fw { background: #1C1C1E; border: 1px solid rgba(255,255,255,0.04); border-radius: 12px; overflow: hidden; transition: border-color 0.2s; }
    .fw:hover { border-color: rgba(255,255,255,0.08); }
    .fw-head { display: flex; align-items: center; gap: 10px; padding: 14px 16px; cursor: pointer; user-select: none; }
    .fw-head:active { transform: scale(0.995); }
    .fw-chevron { width: 16px; height: 16px; color: #48484A; transition: transform 0.2s; flex-shrink: 0; }
    .fw.open .fw-chevron { transform: rotate(90deg); color: #D70030; }
    .fw-name { font-size: 13px; font-weight: 500; flex: 1; }
    .fw-type { font-size: 8px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; padding: 2px 7px; border-radius: 4px; flex-shrink: 0; }
    .t-rule { background: rgba(215,0,48,0.12); color: #D70030; }
    .t-checklist { background: rgba(0,122,255,0.12); color: #0A84FF; }
    .t-pattern { background: rgba(191,90,242,0.12); color: #BF5AF2; }
    .t-template { background: rgba(48,209,88,0.12); color: #30D158; }
    .t-runbook { background: rgba(255,159,10,0.12); color: #FF9F0A; }
    .fw-toggle { width: 32px; height: 18px; border-radius: 9px; background: #2C2C2E; position: relative; cursor: pointer; flex-shrink: 0; transition: background 0.2s; }
    .fw-toggle.on { background: #30D158; }
    .fw-toggle::after { content: ''; position: absolute; top: 2px; left: 2px; width: 14px; height: 14px; border-radius: 50%; background: #FFF; transition: transform 0.2s; }
    .fw-toggle.on::after { transform: translateX(14px); }
    .fw-body { display: none; padding: 0 16px 16px; }
    .fw.open .fw-body { display: block; }
    .fw-desc { font-size: 11px; color: #8E8E93; line-height: 1.5; margin-bottom: 12px; }
    .fw-steps { list-style: none; counter-reset: step; }
    .fw-steps li { counter-increment: step; position: relative; padding: 6px 0 6px 28px; font-size: 11px; color: #AEAEB2; line-height: 1.5; border-bottom: 0.5px solid rgba(255,255,255,0.02); }
    .fw-steps li:last-child { border: none; }
    .fw-steps li::before { content: counter(step); position: absolute; left: 0; top: 6px; width: 18px; height: 18px; border-radius: 5px; background: rgba(215,0,48,0.08); color: #D70030; font-size: 9px; font-weight: 600; display: flex; align-items: center; justify-content: center; }
    .fw-tags-row { display: flex; gap: 4px; margin-top: 10px; flex-wrap: wrap; }
    .fw-tag { font-size: 8px; padding: 2px 6px; border-radius: 3px; background: rgba(255,255,255,0.04); color: #636366; }
    .fw-scope { font-size: 9px; color: #48484A; margin-top: 8px; }

    /* Agent Drawer */
    .drawer-tabs { display: flex; gap: 0; margin-bottom: 12px; border-bottom: 1px solid rgba(255,255,255,0.04); }
    .drawer-tab { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; padding: 8px 12px; background: none; border: none; color: #636366; cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.15s; }
    .drawer-tab.active { color: #D70030; border-bottom-color: #D70030; }
    .drawer-tab:hover { color: #D2D2D7; }
    .drawer-content { max-height: 360px; overflow-y: auto; }
    .drawer-subtitle { font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: #48484A; margin-bottom: 8px; }
    .drawer-chat { display: flex; flex-direction: column; gap: 10px; margin-bottom: 12px; }
    .dc-msg { max-width: 90%; }
    .dc-agent { align-self: flex-start; }
    .dc-user { align-self: flex-end; }
    .dc-text { font-size: 12px; line-height: 1.5; padding: 10px 14px; border-radius: 14px; }
    .dc-agent .dc-text { background: #1C1C1E; color: #D2D2D7; border-bottom-left-radius: 4px; }
    .dc-user .dc-text { background: #D70030; color: #FFF; border-bottom-right-radius: 4px; }
    .dc-time { font-size: 9px; color: #48484A; margin-top: 3px; }
    .dc-user .dc-time { text-align: right; }
    .dc-input-row { display: flex; gap: 6px; }
    .dc-input { flex: 1; background: #1C1C1E; border: 1px solid rgba(255,255,255,0.06); border-radius: 8px; padding: 8px 12px; font-size: 11px; color: #F5F5F7; outline: none; }
    .dc-input:focus { border-color: #D70030; }
    .dc-input::placeholder { color: #48484A; }
    .dc-send { background: #D70030; color: #FFF; border: none; border-radius: 8px; padding: 8px 14px; font-size: 10px; font-weight: 600; cursor: pointer; transition: opacity 0.15s; }
    .dc-send:hover { opacity: 0.85; }
    .train-skills { display: flex; flex-direction: column; gap: 6px; }
    .train-skill { display: flex; align-items: center; justify-content: space-between; padding: 6px 0; border-bottom: 0.5px solid rgba(255,255,255,0.02); }
    .train-skill-name { font-size: 11px; color: #AEAEB2; }
    .train-refs { display: flex; flex-wrap: wrap; gap: 4px; }
    .train-ref { font-size: 9px; padding: 3px 8px; border-radius: 6px; background: rgba(255,255,255,0.04); color: #8E8E93; cursor: pointer; }
    .train-ref:last-child { color: #D70030; background: rgba(215,0,48,0.08); }
    .train-rules { display: flex; flex-direction: column; gap: 4px; }
    .train-rule { font-size: 11px; color: #8E8E93; padding: 6px 0; border-bottom: 0.5px solid rgba(255,255,255,0.02); }
    .config-rows { display: flex; flex-direction: column; }
    .config-row { display: flex; justify-content: space-between; padding: 7px 0; border-bottom: 0.5px solid rgba(255,255,255,0.02); font-size: 11px; }
    .config-label { color: #636366; }
    .config-val { color: #D2D2D7; }

    /* Agent Flow Canvas */
    .flow-canvas { position: relative; background: #050505; border: 1px solid rgba(255,255,255,0.04); border-radius: 14px; height: 340px; overflow: hidden; }
    .flow-grid { position: absolute; inset: 0; opacity: 0.04; background-image: radial-gradient(circle at 1px 1px, #D70030 0.5px, transparent 0); background-size: 40px 40px; }
    .flow-svg { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; }
    .flow-node { position: absolute; text-align: center; z-index: 2; }
    .flow-av { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'Zen Dots', cursive; font-size: 13px; margin: 0 auto 4px; }
    .flow-av-ceo { background: rgba(215,0,48,0.12); border: 1.5px solid rgba(215,0,48,0.4); color: #D70030; }
    .flow-av-w { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); color: #8E8E93; }
    .flow-name { font-size: 11px; font-weight: 500; color: #D2D2D7; }
    .flow-role-label { font-size: 9px; color: #636366; }
    .flow-action-tag { font-size: 8px; font-weight: 500; margin-top: 4px; padding: 2px 8px; border-radius: 4px; background: rgba(215,0,48,0.1); color: #D70030; display: inline-block; }
    .flow-tag-green { background: rgba(48,209,88,0.1); color: #30D158; }
    .flow-tag-blue { background: rgba(10,132,255,0.1); color: #0A84FF; }
    .flow-tag-orange { background: rgba(255,159,10,0.1); color: #FF9F0A; }
    .flow-glow { position: absolute; top: -4px; left: 50%; transform: translateX(-50%); width: 48px; height: 48px; border-radius: 50%; z-index: -1; animation: flowGlow 3s ease-in-out infinite; }
    .flow-glow { box-shadow: 0 0 20px rgba(215,0,48,0.2), 0 0 40px rgba(215,0,48,0.05); }
    .flow-g-green { box-shadow: 0 0 20px rgba(48,209,88,0.2), 0 0 40px rgba(48,209,88,0.05); }
    .flow-g-blue { box-shadow: 0 0 20px rgba(10,132,255,0.2), 0 0 40px rgba(10,132,255,0.05); }
    .flow-g-orange { box-shadow: 0 0 20px rgba(255,159,10,0.2), 0 0 40px rgba(255,159,10,0.05); }
    @keyframes flowGlow { 0%,100% { opacity: 0.4; } 50% { opacity: 1; } }
    .flow-bottom { position: absolute; bottom: 0; left: 0; right: 0; padding: 10px 16px; display: flex; gap: 16px; font-size: 9px; color: #48484A; background: linear-gradient(transparent, #050505); }
    .flow-live-badge { color: #D70030; font-weight: 700; letter-spacing: 0.08em; display: flex; align-items: center; gap: 4px; margin-left: auto; }
    .flow-live-badge::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: #D70030; animation: pulse 1.5s ease infinite; }

    /* Responsive */
    @media (max-width: 900px) {
      .content { grid-template-columns: 1fr; }
      .left-panel { max-height: none; border-right: none; border-bottom: 0.5px solid rgba(255,255,255,0.04); }
      .right-panel { max-height: none; }
      .stats-row { grid-template-columns: repeat(3,1fr); }
    }
  </style>
</head>
<body>

  <header class="header">
    <div class="header-left">
      <span class="logo">KTANA</span>
      <span class="logo-sub">COOK — Orchestrator Brain</span>
    </div>
    <div class="header-right">
      <div class="pulse"></div>
      <span>Operacional</span>
      <span>·</span>
      <span id="clock">--:--</span>
      <span>·</span>
      <a href="../admin/index.html" style="color:#636366;text-decoration:none;font-size:10px;">← Admin</a>
    </div>
  </header>

  <div class="content">

    <!-- LEFT: Agents + Live Feed -->
    <div class="left-panel">

      <div class="panel-section">
        <p class="panel-label">Samurais ativos <span class="panel-count">6 online</span></p>
        <div class="agent-mini active" onclick="openAgent('akira')">
          <div class="a-av a-av-ceo">A</div>
          <div><p class="a-name">Akira</p><p class="a-role">CEO</p></div>
          <div class="a-status on"><span class="dot dot-on"></span> 24</div>
        </div>
        <div class="agent-mini" onclick="openAgent('yuki')">
          <div class="a-av a-av-def">Y</div>
          <div><p class="a-name">Yuki</p><p class="a-role">Controller</p></div>
          <div class="a-status on"><span class="dot dot-on"></span> 47</div>
        </div>
        <div class="agent-mini" onclick="openAgent('hana')">
          <div class="a-av a-av-def">H</div>
          <div><p class="a-name">Hana</p><p class="a-role">Secretaria</p></div>
          <div class="a-status on"><span class="dot dot-on"></span> 58</div>
        </div>
        <div class="agent-mini" onclick="openAgent('haruki')">
          <div class="a-av a-av-def">H</div>
          <div><p class="a-name">Haruki</p><p class="a-role">PM</p></div>
          <div class="a-status on"><span class="dot dot-on"></span> 65</div>
        </div>
        <div class="agent-mini" onclick="openAgent('kaito')">
          <div class="a-av a-av-def">K</div>
          <div><p class="a-name">Kaito</p><p class="a-role">Builder</p></div>
          <div class="a-status on"><span class="dot dot-on"></span> 12</div>
        </div>
        <div class="agent-mini" onclick="openAgent('yumi')">
          <div class="a-av a-av-def">Y</div>
          <div><p class="a-name">Yumi</p><p class="a-role">Mentora PF</p></div>
          <div class="a-status on"><span class="dot dot-on"></span> 8</div>
        </div>
      </div>

      <!-- Agent Detail Drawer (hidden by default) -->
      <div class="panel-section agent-drawer" id="agentDrawer" style="display:none;border-bottom:none;">
        <p class="panel-label"><span id="drawerTitle">Akira — CEO</span> <span class="panel-count" style="cursor:pointer;" onclick="closeAgent()">✕ Fechar</span></p>

        <!-- Tabs -->
        <div class="drawer-tabs">
          <button class="drawer-tab active" onclick="switchDrawerTab(this,'chat')">Chat</button>
          <button class="drawer-tab" onclick="switchDrawerTab(this,'train')">Treinamento</button>
          <button class="drawer-tab" onclick="switchDrawerTab(this,'config')">Config</button>
        </div>

        <!-- Chat Tab -->
        <div class="drawer-content" id="tab-chat">
          <div class="drawer-chat">
            <div class="dc-msg dc-agent">
              <p class="dc-text">Ola Julio. Estou consolidando o briefing diario. 3 aprovacoes pendentes e 1 escalacao do Haruki sobre API Celcoin. Como quer proceder?</p>
              <p class="dc-time" id="drawerAgentName">Akira · 17:05</p>
            </div>
            <div class="dc-msg dc-user">
              <p class="dc-text">Aprova o bypass temporario da Celcoin. Quero o sprint fechado ate sexta.</p>
              <p class="dc-time">Julio · 17:06</p>
            </div>
            <div class="dc-msg dc-agent">
              <p class="dc-text">Entendido. Bypass aprovado. Notifiquei Haruki para retomar as 2 tasks bloqueadas. Sprint sera fechado sexta 18h.</p>
              <p class="dc-time" id="drawerAgentName2">Akira · 17:06</p>
            </div>
          </div>
          <div class="dc-input-row">
            <input type="text" class="dc-input" placeholder="Instruir agente...">
            <button class="dc-send">Enviar</button>
          </div>
        </div>

        <!-- Training Tab -->
        <div class="drawer-content" id="tab-train" style="display:none;">
          <p class="drawer-subtitle">Skills ativas</p>
          <div class="train-skills">
            <div class="train-skill"><span class="train-skill-name">Consolidar briefing diario</span><div class="fw-toggle on" onclick="this.classList.toggle('on')"></div></div>
            <div class="train-skill"><span class="train-skill-name">Delegar tasks para equipe</span><div class="fw-toggle on" onclick="this.classList.toggle('on')"></div></div>
            <div class="train-skill"><span class="train-skill-name">Escalar decisoes pro Shogun</span><div class="fw-toggle on" onclick="this.classList.toggle('on')"></div></div>
            <div class="train-skill"><span class="train-skill-name">Gerar relatorio semanal</span><div class="fw-toggle on" onclick="this.classList.toggle('on')"></div></div>
            <div class="train-skill"><span class="train-skill-name">Aprovar gastos < R$500</span><div class="fw-toggle" onclick="this.classList.toggle('on')"></div></div>
          </div>
          <p class="drawer-subtitle" style="margin-top:16px;">Referencias de personalidade</p>
          <div class="train-refs">
            <span class="train-ref">Steve Jobs</span>
            <span class="train-ref">Elon Musk</span>
            <span class="train-ref">Ray Dalio</span>
            <span class="train-ref">+ Adicionar</span>
          </div>
          <p class="drawer-subtitle" style="margin-top:16px;">Regras exclusivas</p>
          <div class="train-rules">
            <p class="train-rule">Nunca enviar email externo sem aprovacao</p>
            <p class="train-rule">Sempre incluir ROI estimado nas propostas</p>
            <p class="train-rule">Check-in diario as 08:00 via WhatsApp</p>
          </div>
        </div>

        <!-- Config Tab -->
        <div class="drawer-content" id="tab-config" style="display:none;">
          <div class="config-rows">
            <div class="config-row"><span class="config-label">Modelo LLM</span><span class="config-val">Sonnet 4.6</span></div>
            <div class="config-row"><span class="config-label">Fallback</span><span class="config-val">Haiku 4.5</span></div>
            <div class="config-row"><span class="config-label">Temperatura</span><span class="config-val">0.3</span></div>
            <div class="config-row"><span class="config-label">Max tokens/dia</span><span class="config-val">50.000</span></div>
            <div class="config-row"><span class="config-label">Custo/mes</span><span class="config-val">R$420</span></div>
            <div class="config-row"><span class="config-label">Conexoes</span><span class="config-val">Gmail, WhatsApp, ClickUp</span></div>
